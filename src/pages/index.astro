---
import { Image } from "astro:assets";
import Layout from "../layouts/Layout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
 
// ── Imágenes del hero / proyectos ────────────────────────────────────────────
import logo from "../assets/logos/stuttgart-logo.svg";
import tablero01 from "../assets/gallery/tableros/tablero-01.jpg";
import medicion01 from "../assets/gallery/mediciones/medicion-01.jpg";
import medicion02 from "../assets/gallery/mediciones/medicion-02.jpg";
import p4_7 from "../assets/gallery/stuttgart_proyecto_4/proyecto_4-07.jpg";
---
 
<Layout title="Stuttgart Ingeniería Electrónica">
  <Navbar isHome={true} currentPage="home" />
 
  <!-- ══ HERO ══════════════════════════════════════════════════════════════ -->
  <header
    id="inicio"
    class="relative min-h-screen flex items-center justify-center overflow-hidden bg-black text-white px-6 pt-24"
  >
    <div class="absolute inset-0 bg-linear-to-b from-orange-950/50 via-black to-black"></div>
    <div class="absolute -top-30 left-1/2 -translate-x-1/2 w-175 h-175 rounded-full bg-orange-500/20 blur-3xl pointer-events-none"></div>
    <div class="absolute -bottom-37.5 -right-30 w-112.5 h-112.5 rounded-full bg-amber-400/10 blur-3xl pointer-events-none"></div>
 
    <div class="relative z-10 max-w-5xl text-center reveal reveal-up">
      <Image
        src={logo}
        alt="Stuttgart Ingeniería Electrónica"
        class="mb-6 h-16 md:h-20 w-auto mx-auto"
      />
 
      <h1 class="text-5xl md:text-7xl font-bold tracking-tight leading-tight mb-6">
        Soluciones técnicas para
        <span class="block bg-linear-to-r from-orange-300 via-orange-500 to-amber-300 bg-clip-text text-transparent">
          obras eléctricas, tableros y mediciones
        </span>
      </h1>
 
      <p class="max-w-3xl mx-auto text-zinc-300 text-lg md:text-xl mb-10 leading-8">
       Stuttgart es una empresa de ingeniería orientada a obras, instalaciones de tableros, mediciones eléctricas, tramites y servicios técnicos vinculados a la ingeniería eléctrica y seguridad, con enfoque en calidad y cumplimiento normativo. 
      </p>
 
      <div class="flex flex-wrap justify-center gap-4">
        <a
          href="#servicios"
          class="rounded-xl bg-white px-6 py-3 font-medium text-black transition hover:scale-105 focus-visible:outline focus-visible:outline-2 focus-visible:outline-orange-400"
        >
          Ver servicios
        </a>
        <a
          href="#contacto"
          class="inline-flex items-center justify-center rounded-xl bg-linear-to-r from-orange-500 to-amber-500 px-6 py-3 font-medium text-white shadow-[0_12px_30px_rgba(249,115,22,0.28)] transition hover:scale-[1.02] hover:shadow-[0_16px_40px_rgba(249,115,22,0.35)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-orange-400"
        >
          Solicitar contacto
        </a>
      </div>
    </div>
  </header>
 
  <!-- ══ ABOUT ══════════════════════════════════════════════════════════════ -->
  <section
    id="about"
    class="relative overflow-hidden bg-linear-to-b from-black via-zinc-950 to-black text-white px-6 py-24"
  >
    <div class="absolute -top-20 right-0 w-105 h-105 rounded-full bg-orange-500/10 blur-3xl pointer-events-none"></div>
 
    <div class="relative max-w-6xl mx-auto grid md:grid-cols-2 gap-12 items-center">
      <div class="reveal reveal-left">
        <p class="text-orange-400 text-sm uppercase tracking-[0.2em] mb-3">Nosotros</p>
        <h2 class="text-4xl md:text-5xl font-bold mb-6">
          Ingeniería técnica con foco en confiabilidad operativa
        </h2>
 
        <p class="text-zinc-400 leading-8 mb-5">
          En Stuttgart desarrollamos soluciones para instalaciones eléctricas,
          tableros de distribución y maniobra, mediciones técnicas y controles de
          seguridad, adaptándonos a requerimientos industriales, comerciales y de obra.
        </p>
 
        <p class="text-zinc-400 leading-8 mb-5">
          Nuestro trabajo combina criterio ingenieril, ejecución técnica y documentación
          clara, con el objetivo de entregar sistemas seguros, ordenados y preparados
          para operar con continuidad.
        </p>
 
        <p class="text-zinc-400 leading-8">
          Intervenimos en proyectos nuevos, adecuaciones, mantenimiento técnico y
          verificaciones, acompañando al cliente desde el relevamiento hasta la
          implementación y control final.
        </p>
      </div>
 
      <div class="reveal reveal-right rounded-3xl border border-white/10 bg-linear-to-br from-zinc-900 to-zinc-950 p-8 shadow-2xl">
        <p class="text-orange-400 text-sm uppercase tracking-[0.2em] mb-4">
          Enfoque de trabajo
        </p>
        <h3 class="text-2xl md:text-3xl font-semibold mb-6">
          Soluciones técnicas con criterio, orden y seguridad
        </h3>
 
        <div class="space-y-5 text-zinc-400 leading-8">
          <div class="border-l-2 border-orange-400/50 pl-4">
            <p class="text-white font-medium mb-1">Obras y tableros</p>
            <p>
              Montaje, adecuación, puesta en servicio de instalaciones y tableros eléctricos de distribución, maniobra y protección.
            </p>
          </div>
          <div class="border-l-2 border-orange-400/50 pl-4">
            <p class="text-white font-medium mb-1">Medición, verificación y certificación</p>
            <p>
              Certificaciones, tramites, DCI, Res. 900/15, medición de calidad de energía.
            </p>
          </div>
          <div class="border-l-2 border-orange-400/50 pl-4">
            <p class="text-white font-medium mb-1">Diagnóstico y mantenimiento</p>
            <p>
             Mantenimiento preventivo y correctivo, detección de falla y adecuaciones para mejorar confiabilidad operativa y seguridad eléctrica.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>
 
  <!-- ══ SERVICIOS ══════════════════════════════════════════════════════════ -->
  <section
    id="servicios"
    class="relative overflow-hidden bg-linear-to-b from-black via-orange-950/10 to-black text-white px-6 py-24"
  >
    <div class="absolute -left-25 top-10 w-80 h-80 rounded-full bg-amber-500/10 blur-3xl pointer-events-none"></div>
 
    <div class="relative max-w-6xl mx-auto">
      <p class="text-orange-400 text-sm uppercase tracking-[0.2em] mb-3 reveal reveal-up">
        Servicios
      </p>
      <h2 class="text-4xl md:text-5xl font-bold mb-12 reveal reveal-up">
        Servicios técnicos especializados
      </h2>
 
      <div class="grid md:grid-cols-2 xl:grid-cols-3 gap-6">
        {[
          {
            titulo: "Obras eléctricas",
            texto: "Obras comerciales, industriales y multi-familiares con enfoque en calidad y seguridad eléctrica.",
          },
          {
            titulo: "Tableros eléctricos",
            texto: "Montaje, conexionado, adecuación y puesta en servicio de tableros eléctricos de distribución, maniobra, protección y control.",
          },
          {
            titulo: "Tramites y certificaciones",
            texto: "Documentación técnica, planos, certificaciones, DCI, Res. 900/15 y habilitación de medidores.",
          },
          {
            titulo: "Mediciones eléctricas",
            texto: "Medición de puesta a tierra, potencia, calidad de energía y controles técnicos para validar condiciones operativas y de seguridad eléctrica.",
          },
          {
            titulo: "Seguridad electrónica",
            texto: "Instalación de camaras de seguridad, sistemas de control de acceso, alarmas, cercos y otros dispositivos electrónicos para mejorar la seguridad física en instalaciones industriales, comerciales o residenciales.",
          },
          {
            titulo: "Mantenimiento preventivo y correctivo",
            texto: "Mantenimiento preventivo y correctivo de instalaciones eléctricas, tableros, sistemas de protección y componentes relacionados para mejorar confiabilidad operativa y seguridad eléctrica.",
          },
        ].map((s) => (
          <article class="reveal reveal-up rounded-3xl border border-white/10 bg-linear-to-br from-zinc-900 to-zinc-950 p-6 transition hover:border-orange-400/40 hover:scale-[1.02]">
            <div class="mb-4 w-10 h-10 rounded-xl bg-orange-400/10 border border-orange-400/20 flex items-center justify-center">
              <span class="w-2.5 h-2.5 rounded-full bg-orange-400"></span>
            </div>
            <h3 class="text-xl font-semibold mb-3">{s.titulo}</h3>
            <p class="text-zinc-400 leading-7 text-sm">{s.texto}</p>
          </article>
        ))}
      </div>
    </div>
  </section>
 
  <!-- ══ PROYECTOS ══════════════════════════════════════════════════════════ -->
  <section
    id="proyectos"
    class="relative overflow-hidden bg-linear-to-b from-black via-zinc-950 to-black text-white px-6 py-24"
  >
    <div class="absolute -right-25 top-20 w-90 h-90 rounded-full bg-orange-500/10 blur-3xl pointer-events-none"></div>
 
    <div class="relative max-w-6xl mx-auto">
      <p class="text-orange-400 text-sm uppercase tracking-[0.2em] mb-3 reveal reveal-up">
        Proyectos
      </p>
      <h2 class="text-4xl md:text-5xl font-bold mb-12 reveal reveal-up">
        Experiencia técnica y casos de aplicación
      </h2>
 
      <div class="grid md:grid-cols-2 gap-6">
        <!-- Proyecto 01 -->
        <article class="reveal reveal-up group overflow-hidden rounded-3xl border border-white/10 bg-linear-to-br from-zinc-900 to-zinc-950 transition hover:border-orange-400/40">
          <div class="aspect-16/10 w-full overflow-hidden bg-zinc-950">
            <Image
              src={tablero01}
              alt="Instalación de tablero eléctrico"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <p class="text-orange-400 text-[11px] uppercase tracking-[0.2em] mb-2">Tableros eléctricos</p>
            <h3 class="text-xl font-semibold mb-3 group-hover:text-orange-400 transition">
              Proyecto 01 · Tableros eléctricos
            </h3>
            <p class="text-zinc-400 leading-7 text-sm">
              Desarrollo e instalación de tableros con criterio de orden, protección,
              maniobra y mantenimiento, adaptados a requerimientos operativos del cliente.
            </p>
          </div>
        </article>
 
        <!-- Proyecto 02 -->
        <article class="reveal reveal-up group overflow-hidden rounded-3xl border border-white/10 bg-linear-to-br from-zinc-900 to-zinc-950 transition hover:border-orange-400/40">
          <div class="aspect-16/10 w-full overflow-hidden bg-zinc-950">
            <Image
              src={medicion01}
              alt="Medición eléctrica en campo"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <p class="text-orange-400 text-[11px] uppercase tracking-[0.2em] mb-2">Mediciones y verificación</p>
            <h3 class="text-xl font-semibold mb-3 group-hover:text-orange-400 transition">
              Proyecto 02 · Mediciones y verificación
            </h3>
            <p class="text-zinc-400 leading-7 text-sm">
              Controles técnicos sobre instalaciones y equipos para validar estado,
              funcionamiento y condiciones generales de seguridad eléctrica.
            </p>
          </div>
        </article>
 
        <!-- Proyecto 03 -->
        <article class="reveal reveal-up group overflow-hidden rounded-3xl border border-white/10 bg-linear-to-br from-zinc-900 to-zinc-950 transition hover:border-orange-400/40">
          <div class="aspect-16/10 w-full overflow-hidden bg-zinc-950">
            <Image
              src={medicion02}
              alt="Verificación técnica de instalación"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <p class="text-orange-400 text-[11px] uppercase tracking-[0.2em] mb-2">Verificación técnica</p>
            <h3 class="text-xl font-semibold mb-3 group-hover:text-orange-400 transition">
              Proyecto 03 · Verificación técnica
            </h3>
            <p class="text-zinc-400 leading-7 text-sm">
              Relevamiento, control y documentación técnica para validar condiciones
              operativas y de seguridad en instalaciones existentes.
            </p>
          </div>
        </article>
 
        <!-- Proyecto 04 -->
        <article class="reveal reveal-up group overflow-hidden rounded-3xl border border-white/10 bg-linear-to-br from-zinc-900 to-zinc-950 transition hover:border-orange-400/40">
          <div class="aspect-16/10 w-full overflow-hidden bg-zinc-950">
            <Image
              src={p4_7}
              alt="Instalación eléctrica Proyecto 4"
              class="h-full w-full object-cover transition duration-500 group-hover:scale-105"
              loading="lazy"
            />
          </div>
          <div class="p-6">
            <p class="text-orange-400 text-[11px] uppercase tracking-[0.2em] mb-2">Instalaciones eléctricas</p>
            <h3 class="text-xl font-semibold mb-3 group-hover:text-orange-400 transition">
              Proyecto 04 · Instalaciones eléctricas
            </h3>
            <p class="text-zinc-400 leading-7 text-sm">
              Intervención integral de luminaria en edificio comercial, incluyendo
              montaje, conexionado y puesta en servicio de tableros de distribución y maniobra.
            </p>
          </div>
        </article>
      </div>
 
      <div class="mt-10 text-center reveal reveal-up">
        <a
          href="/galeria"
          class="inline-flex items-center gap-2 rounded-xl border border-white/15 px-6 py-3 font-medium text-white transition hover:border-orange-400/50 hover:bg-white hover:text-black focus-visible:outline focus-visible:outline-2 focus-visible:outline-orange-400"
        >
          Ver galería completa
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
 
  <!-- ══ CONTACTO ═══════════════════════════════════════════════════════════ -->
  <section
    id="contacto"
    class="relative overflow-hidden bg-linear-to-b from-black via-orange-950/10 to-black text-white px-6 py-24"
  >
    <div class="absolute left-0 bottom-0 w-85 h-85 rounded-full bg-orange-500/10 blur-3xl pointer-events-none"></div>
 
    <div class="relative max-w-6xl mx-auto rounded-3xl border border-white/10 bg-linear-to-br from-zinc-900 to-zinc-950 p-10 md:p-14 reveal reveal-up">
      <p class="text-orange-400 text-sm uppercase tracking-[0.2em] mb-3">Contacto</p>
      <h2 class="text-4xl md:text-5xl font-bold mb-6">
        Hablemos de tu próxima obra o requerimiento técnico
      </h2>
 
      <p class="max-w-2xl text-zinc-400 leading-8 mb-8">
       Si necesitás realizar una obra, tableros, tramites, mediciones o asistencia técnica en ingeniería eléctrica, podemos ayudarte. 
      </p>
 
      <div class="flex flex-wrap gap-4">
        <a
          href="https://wa.me/5491123921232"
          class="rounded-xl bg-gradient-to-r from-[#25D366] via-[#1ebe5d] to-[#075E54] px-6 py-3 font-medium text-white transition hover:scale-105 hover:brightness-110 "
          target="_blank"
          rel="noopener noreferrer"
        >
          WhatsApp
        </a>
        <a
          href="https://www.instagram.com/stuttingenieria/"
          class="rounded-xl border border-white/15 px-6 py-3 font-medium text-white transition hover:border-orange-400/50 hover:bg-white hover:text-black focus-visible:outline focus-visible:outline-2 focus-visible:outline-orange-400"
          target="_blank"
          rel="noopener noreferrer"
        >
          Instagram
        </a>
        <a
          href="mailto:presupuestos@stuttingenieria.com"
          class="rounded-xl border border-white/15 px-6 py-3 font-medium text-white transition hover:border-orange-400/50 hover:bg-white hover:text-black focus-visible:outline focus-visible:outline-2 focus-visible:outline-orange-400"
        >
          Email
        </a>
        <a
          href="/unite"
          class="rounded-xl border border-orange-400/40 px-6 py-3 font-medium text-white transition hover:border-orange-400/80 hover:bg-orange-400/10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-orange-400"
        >
          Únete al equipo
        </a>
      </div>
    </div>
  </section>
 
  <!-- ══ FAQ ════════════════════════════════════════════════════════════════ -->
  <section
    id="faq"
    class="relative overflow-hidden bg-linear-to-b from-black via-zinc-950 to-black text-white px-6 pb-24"
  >
    <div class="absolute right-0 top-0 w-75 h-75 rounded-full bg-amber-500/10 blur-3xl pointer-events-none"></div>
 
    <div class="relative max-w-6xl mx-auto">
      <p class="text-orange-400 text-sm uppercase tracking-[0.2em] mb-3 reveal reveal-up">
        Preguntas frecuentes
      </p>
      <h2 class="text-4xl md:text-5xl font-bold mb-10 reveal reveal-up">
        Respuestas rápidas
      </h2>
 
      <div class="space-y-4">
        {[
                    {
            q: "¿Por qué Stuttgart?",
            a: "Stuttgart nace como una referencia a la experiencia formativa de nuestro Director Técnico en el Instituto Tecnológico de Karlsruhe, en Alemania, una etapa que marcó su visión sobre la ingeniería, la organización y la calidad aplicada al trabajo. El nombre refleja ese enfoque: hacer instalaciones eléctricas con criterio técnico, orden y profesionalismo.",
          },
          {
            q: "¿Ofrecen alguna garantía?",
            a: "Sí, todos nuestros trabajos cuentan con garantía. Nos aseguramos de cumplir con normativa vigente y estándares de calidad, brindando respaldo tanto en la ejecución como en los materiales utilizados.",
          },
           {
            q: "¿Dónde realizan los trabajos?",
            a: "Abarcamos proyectos en CABA, GBA y zonas aledañas. Para obras o servicios fuera de esta área, evaluamos cada caso para ofrecer la mejor solución técnica y logística.",
          },
          {
            q: "¿Están matriculados?",
            a: "Sí, contamos con dirección técnica a cargo de un técnico electromecánico matriculado, lo que nos permite firmar trabajos, realizar mediciones normativas y garantizar cumplimiento con reglamentaciones vigentes.",
          },
          {
            q: "¿Qué formas de pago aceptan?",
            a: "Trabajamos con transferencia bancaria, efectivo y otros medios a coordinar según el tipo de obra. En proyectos más grandes, se establecen esquemas de pago por etapas.",
          },
           {
            q: "¿Cuál es el horario de atención?",
            a: "Estamos disponibles de lunes a viernes de 8 a 18 hs para consultas, relevamientos y trabajos. Para casos de urgencia o requerimientos fuera de este horario, por favor contactanos para evaluar la situación.",
          },
          {
            q: "¿Cómo puedo solicitar una consulta técnica?",
            a: "Podés contactarnos por WhatsApp o correo electrónico para coordinar un primer relevamiento o consulta según tu necesidad.",
          },
        ].map((item) => (
          <details class="reveal reveal-up group rounded-2xl border border-white/10 bg-linear-to-br from-zinc-900 to-zinc-950 p-6 transition hover:border-orange-400/40">
            <summary class="cursor-pointer list-none flex items-center justify-between text-lg font-semibold">
              {item.q}
              <span class="ml-4 shrink-0 text-orange-400 transition group-open:rotate-45">+</span>
            </summary>
            <p class="mt-4 text-zinc-400 leading-7">{item.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>
    <!-- BOTÓN FLOTANTE WHATSAPP -->
  <a
    href="https://wa.me/5491123921232"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Contactar por WhatsApp"
    class="fixed bottom-6 right-6 z-50 flex h-16 w-16 items-center justify-center rounded-full border-2 border-white bg-gradient-to-br from-[#25D366] via-[#1ebe5d] to-[#128C7E] text-white shadow-lg shadow-green-500/30 transition hover:scale-110 hover:brightness-110 animate-[pulse_2.5s_infinite]"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 32 32"
      fill="currentColor"
      class="h-8 w-8"
    >
      <path d="M19.11 17.34c-.28-.14-1.65-.81-1.91-.9-.25-.09-.44-.14-.62.14-.18.28-.71.9-.87 1.08-.16.19-.32.21-.6.07-.28-.14-1.16-.43-2.2-1.36-.81-.72-1.36-1.62-1.52-1.9-.16-.28-.02-.43.12-.57.13-.13.28-.32.42-.48.14-.16.18-.28.28-.46.09-.19.05-.35-.02-.49-.07-.14-.62-1.5-.85-2.06-.22-.52-.45-.45-.62-.46h-.53c-.19 0-.49.07-.74.35-.25.28-.97.95-.97 2.31 0 1.36.99 2.67 1.13 2.85.14.19 1.95 2.98 4.72 4.18.66.28 1.17.44 1.57.56.66.21 1.25.18 1.72.11.53-.08 1.65-.67 1.88-1.32.23-.65.23-1.2.16-1.32-.07-.12-.25-.19-.53-.32Z" />
      <path d="M16.03 3.2c-7.07 0-12.8 5.73-12.8 12.8 0 2.26.59 4.47 1.71 6.42L3.2 28.8l6.55-1.71a12.75 12.75 0 0 0 6.28 1.68h.01c7.06 0 12.79-5.73 12.79-12.8 0-3.42-1.33-6.63-3.75-9.05A12.7 12.7 0 0 0 16.03 3.2Zm0 23.3h-.01a10.5 10.5 0 0 1-5.35-1.47l-.38-.22-3.89 1.01 1.04-3.79-.25-.39a10.49 10.49 0 0 1-1.61-5.63c0-5.79 4.71-10.5 10.51-10.5 2.8 0 5.42 1.09 7.4 3.07a10.4 10.4 0 0 1 3.08 7.43c0 5.79-4.71 10.49-10.5 10.49Z" />
    </svg>
  </a>
<div class="fixed bottom-6 right-6 z-50 group">
  <a
    href="https://wa.me/5491123921232"
    target="_blank"
    rel="noopener noreferrer"
    aria-label="Contactar por WhatsApp"
    class="flex h-16 w-16 items-center justify-center rounded-full border-2 border-white bg-gradient-to-br from-[#25D366] via-[#1ebe5d] to-[#128C7E] text-white shadow-lg shadow-green-500/30 transition hover:scale-110 hover:brightness-110"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      viewBox="0 0 32 32"
      fill="currentColor"
      class="h-8 w-8"
